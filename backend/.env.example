DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-dev-only-key-change-before-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_CORS_ALLOWED_ORIGINS=
DJANGO_CORS_ALLOWED_ORIGIN_PREFIXES=http://localhost:,https://localhost:,http://127.0.0.1:,https://127.0.0.1:
DJANGO_DB_PATH=/app/data/db.sqlite3
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_USE_X_FORWARDED_PORT=0
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
EVENT_FRONTEND_URL=http://localhost:8001/warm2026/
