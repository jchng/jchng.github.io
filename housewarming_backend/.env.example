DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-dev-only-key-change-before-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_CORS_ALLOWED_ORIGINS=
DJANGO_CORS_ALLOWED_ORIGIN_PREFIXES=http://localhost:,https://localhost:,http://127.0.0.1:,https://127.0.0.1:
DJANGO_DB_PATH=/app/data/db.sqlite3
