DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-this-with-a-real-secret
DJANGO_ALLOWED_HOSTS=api.jchng.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.jchng.com
DJANGO_CORS_ALLOWED_ORIGINS=https://jchng.com,https://www.jchng.com
DJANGO_CORS_ALLOWED_ORIGIN_PREFIXES=
DJANGO_DB_PATH=/app/data/db.sqlite3
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_USE_X_FORWARDED_PORT=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
EVENT_FRONTEND_URL=https://jchng.com/warm2026/
